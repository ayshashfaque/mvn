pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/ayshashfaque/mvn.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Copy Artifact') {
            steps {
                sh 'mkdir -p dest'
                sh 'cp target/*.jar dest/'
            }
        }

        stage('Deploy') {
            steps {
                sh 'ansible-playbook -i inventory playbook.yml'
            }
        }

    }
}
